</style>


# Put to body after <div id="app"></div>
<script>
    window.$docsify = {
        name: 'Simsoft DataFlow',
        nameLink: 'https://sim-soft.github.io/http-client/',
        repo: 'https://github.com/sim-soft/http-client',
        loadSidebar: true,
        subMaxLevel: 3,
        auto2top: true,
        search: {
            placeholder: 'Search documentation',
            noData: 'No results found',
            depth: 3
        },
        darklightTheme: {
            defaultTheme: 'light',
            siteFont: 'Source Sans Pro, Helvetica Neue, Arial, sans-serif',
            codeFontFamily: 'JetBrains Mono, Roboto Mono, Monaco, courier, monospace',
            dark: {
                accent: '#E8960C',
                toogleBackground: '#1a1a2e',
                background: '#1a1a2e',
                textColor: '#e0e0e0',
                codeBackgroundColor: '#0d1117',
            },
            light: {
                accent: '#C47A08',
                toogleBackground: '#fff',
                background: '#fff',
                textColor: '#1a1a1a',
                codeBackgroundColor: '#f6f8fa',
            },
        }
    };
</script>

# Put at the bottom of the body tag.
<!-- Title prefix plugin -->
<script>
window.$docsify.plugins = (window.$docsify.plugins || []).concat(function(hook) {
  hook.doneEach(function() {
    var title = document.querySelector('.markdown-section h1');
    document.title = 'Simsoft DataFlow' + (title ? ' - ' + title.textContent : '');
  });
});
</script>


